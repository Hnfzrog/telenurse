# Neon PostgreSQL connection string (Transaction connection)
# Connect to Neon dashboard -> Project -> Dashboard -> Connection Details
# Make sure to get the pooled connection string (usually has ?pgbouncer=true or uses the pooled endpoint)
DATABASE_URL="postgresql://user:password@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection for Prisma migrations
# This should be the direct connection string (no pgbouncer)
DIRECT_URL="postgresql://user:password@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ==============================================================================
# AUTHENTICATION (NextAuth)
# ==============================================================================
